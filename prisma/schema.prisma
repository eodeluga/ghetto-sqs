datasource database {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model QueueMessage {
  id                   String   @id @default(auto()) @map("_id") @database.ObjectId
  body                 Json
  createdAt            DateTime @default(now())
  deadLetterQueueName  String?
  maxReceiveCount      Int?
  messageDeduplicationId String?
  messageGroupId       String?
  queueName            String
  receiptHandleHash    String?
  receiveCount         Int      @default(0)
  serviceUserUuid      String
  sourceQueueName      String?
  visibleAt            DateTime @default(now())

  @@index([createdAt])
  @@index([queueName, serviceUserUuid, visibleAt, createdAt])
  @@index([queueName, serviceUserUuid, messageGroupId, visibleAt, createdAt])
  @@index([queueName, serviceUserUuid, messageDeduplicationId, createdAt])
}

model ServiceHandle {
  id                              String   @id @default(auto()) @map("_id") @database.ObjectId
  createdAt                       DateTime @default(now())
  defaultMaxReceiveCount          Int      @default(5)
  defaultVisibilityTimeoutSeconds Int      @default(30)
  label                           String   @unique
  signingKey                      String
  signingKeyHash                  String
  userUuid                        String   @unique
}
