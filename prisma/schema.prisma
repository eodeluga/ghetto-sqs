datasource database {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model QueueMessage {
  id                String   @id @default(auto()) @map("_id") @database.ObjectId
  body              Json
  createdAt         DateTime @default(now())
  queueName         String
  receiptHandleHash String?
  receiveCount      Int      @default(0)
  serviceUserUuid   String
  visibleAt         DateTime @default(now())

  @@index([createdAt])
  @@index([queueName, serviceUserUuid, visibleAt])
}

model ServiceHandle {
  id             String   @id @default(auto()) @map("_id") @database.ObjectId
  createdAt      DateTime @default(now())
  label          String
  signingKey     String
  signingKeyHash String
  userUuid       String   @unique

  @@index([label])
}
