datasource database {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model QueueMessage {
  id                   String   @id @default(auto()) @map("_id") @database.ObjectId
  body                 Json
  createdAt            DateTime @default(now())
  deadLetterQueueName  String?
  maxReceiveCount      Int?
  messageDeduplicationId String?
  messageGroupId       String?
  queueName            String
  receiptHandleHash    String?
  receiveCount         Int      @default(0)
  sourceQueueName      String?
  visibilityChangeCount Int      @default(0)
  visibleAt            DateTime @default(now())

  @@index([createdAt])
  @@index([queueName, visibleAt, createdAt])
  @@index([queueName, messageGroupId, visibleAt, createdAt])
  @@index([queueName, messageDeduplicationId, createdAt])
}

model AuditEvent {
  id                   String   @id @default(auto()) @map("_id") @database.ObjectId
  action               String
  createdAt            DateTime @default(now())
  details              Json?
  targetId             String
  targetType           String

  @@index([createdAt])
  @@index([targetType, targetId, createdAt])
}
