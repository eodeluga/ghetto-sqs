datasource database {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model QueueMessage {
  id                     String   @id @default(auto()) @map("_id") @database.ObjectId
  approximateReceiveCount Int      @default(0)
  body                   Json
  currentReceiptHandle   String?
  deadLetterQueueName    String?
  maxReceiveCount        Int?
  messageDeduplicationId String?
  messageGroupId         String?
  queueName              String
  sentTimestamp          DateTime @default(now())
  sourceQueueName        String?
  visibilityChangeCount  Int      @default(0)
  visibilityExpiresAt    DateTime?

  @@index([sentTimestamp])
  @@index([queueName, visibilityExpiresAt, sentTimestamp])
  @@index([queueName, messageGroupId, visibilityExpiresAt, sentTimestamp])
  @@index([queueName, messageDeduplicationId, sentTimestamp])
}

model AuditEvent {
  id                   String   @id @default(auto()) @map("_id") @database.ObjectId
  action               String
  createdAt            DateTime @default(now())
  details              Json?
  targetId             String
  targetType           String

  @@index([createdAt])
  @@index([targetType, targetId, createdAt])
}
