datasource database {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model QueueMessage {
  id                   String   @id @default(auto()) @map("_id") @database.ObjectId
  body                 Json
  createdAt            DateTime @default(now())
  deadLetterQueueName  String?
  maxReceiveCount      Int?
  messageDeduplicationId String?
  messageGroupId       String?
  queueName            String
  receiptHandleHash    String?
  receiveCount         Int      @default(0)
  serviceUserUuid      String
  sourceQueueName      String?
  visibilityChangeCount Int      @default(0)
  visibleAt            DateTime @default(now())

  @@index([createdAt])
  @@index([queueName, serviceUserUuid, visibleAt, createdAt])
  @@index([queueName, serviceUserUuid, messageGroupId, visibleAt, createdAt])
  @@index([queueName, serviceUserUuid, messageDeduplicationId, createdAt])
}

model ServiceHandle {
  id                              String   @id @default(auto()) @map("_id") @database.ObjectId
  activeKeyVersion                Int      @default(1)
  createdAt                       DateTime @default(now())
  defaultMaxReceiveCount          Int      @default(5)
  defaultVisibilityTimeoutSeconds Int      @default(30)
  label                           String   @unique
  revokedAt                       DateTime?
  userUuid                        String   @unique
}

model ServiceSigningKey {
  id                  String   @id @default(auto()) @map("_id") @database.ObjectId
  createdAt           DateTime @default(now())
  encryptedSigningKey String
  keyVersion          Int
  revokedAt           DateTime?
  serviceUserUuid     String

  @@index([serviceUserUuid, revokedAt, keyVersion])
  @@unique([serviceUserUuid, keyVersion])
}

model SignedRequestNonce {
  id              String   @id @default(auto()) @map("_id") @database.ObjectId
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  nonce           String
  serviceUserUuid String

  @@index([expiresAt])
  @@unique([serviceUserUuid, nonce])
}

model AuditEvent {
  id                   String   @id @default(auto()) @map("_id") @database.ObjectId
  action               String
  actorServiceUserUuid String?
  createdAt            DateTime @default(now())
  details              Json?
  targetId             String
  targetType           String

  @@index([createdAt])
  @@index([targetType, targetId, createdAt])
}
